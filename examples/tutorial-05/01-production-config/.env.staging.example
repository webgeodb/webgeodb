# Staging Environment Variables
# Copy this file to .env.staging and update with your values

# Environment
WEBGEODB_ENVIRONMENT=staging
WEBGEODB_VERSION=1.0.0

# Database Configuration
WEBGEODB_DATABASE_NAME=webgeodb_staging
WEBGEODB_STORAGE_QUOTA=262144000
WEBGEODB_INDEX_PATH=/data/webgeodb/staging
WEBGEODB_BACKUP_PATH=/data/webgeodb/backups

# Compression
WEBGEODB_ENABLE_COMPRESSION=true

# Encryption
WEBGEODB_ENABLE_ENCRYPTION=true
# WEBGEODB_ENCRYPTION_KEY=your-staging-encryption-key-min-32-characters

# Cache
WEBGEODB_CACHE_SIZE=1000

# Logging
WEBGEODB_LOG_LEVEL=info
WEBGEODB_DEBUG=false

# Cleanup
WEBGEODB_AUTO_CLEANUP=true

# Monitoring
WEBGEODB_ENABLE_MONITORING=true
