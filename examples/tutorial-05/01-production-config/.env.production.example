# Production Environment Variables
# Copy this file to .env.production and update with your values

# Environment
WEBGEODB_ENVIRONMENT=production
WEBGEODB_VERSION=1.0.0

# Database Configuration
WEBGEODB_DATABASE_NAME=webgeodb_prod
WEBGEODB_STORAGE_QUOTA=52428800
WEBGEODB_INDEX_PATH=/data/webgeodb/prod
WEBGEODB_BACKUP_PATH=/data/webgeodb/backups

# Compression
WEBGEODB_ENABLE_COMPRESSION=true

# Encryption (Required in production)
WEBGEODB_ENABLE_ENCRYPTION=true
# Generate a secure 32+ character key for production
# WEBGEODB_ENCRYPTION_KEY=your-secure-encryption-key-min-32-characters

# Cache
WEBGEODB_CACHE_SIZE=2000

# Logging
WEBGEODB_LOG_LEVEL=warn
WEBGEODB_DEBUG=false

# Cleanup
WEBGEODB_AUTO_CLEANUP=true

# Monitoring
WEBGEODB_ENABLE_MONITORING=true
