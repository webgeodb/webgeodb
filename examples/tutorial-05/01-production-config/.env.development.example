# Development Environment Variables
# Copy this file to .env.development and update with your values

# Environment
WEBGEODB_ENVIRONMENT=development
WEBGEODB_VERSION=1.0.0

# Database Configuration
WEBGEODB_DATABASE_NAME=webgeodb_dev
WEBGEODB_STORAGE_QUOTA=104857600
WEBGEODB_INDEX_PATH=/data/webgeodb/dev

# Compression
WEBGEODB_ENABLE_COMPRESSION=false

# Encryption
WEBGEODB_ENABLE_ENCRYPTION=false

# Cache
WEBGEODB_CACHE_SIZE=500

# Logging
WEBGEODB_LOG_LEVEL=debug
WEBGEODB_DEBUG=true

# Cleanup
WEBGEODB_AUTO_CLEANUP=false

# Monitoring
WEBGEODB_ENABLE_MONITORING=true
